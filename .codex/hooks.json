{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/docs-guard.sh\""
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/plan-reminder.sh\""
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/plan-state-guard.sh\""
          }
        ]
      }
    ]
  }
}
