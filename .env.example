# Skopiuj ten plik do `.env` i uzupelnij potrzebne wartosci.

HF_TOKEN=hf_...
ECHO_WHISPER_MODEL=large-v3-turbo
ECHO_WHISPER_DEVICE=cpu
ECHO_WHISPER_COMPUTE_TYPE=auto
ECHO_DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
ECHO_ALIGNMENT_ENABLED=true
ECHO_ASR_FILTER_PRESET=full
ECHO_DIARIZATION_FILTER_PRESET=none
ECHO_DIARIZATION_STRICT=false
ECHO_SPEAKER_OVERLAP_THRESHOLD_SECONDS=0.05
ECHO_SEGMENT_MERGE_GAP_SECONDS=1.2
ECHO_LANGUAGE_HINT=pl
